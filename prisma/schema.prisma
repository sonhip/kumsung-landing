generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ContactSubmission {
  id                String   @id @default(cuid())
  name              String
  email             String
  subject           String?
  message           String
  source            String   @default("website")
  ipAddress         String?
  userAgent         String?
  recaptchaVerified Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model MediaAsset {
  id          String   @id @default(cuid())
  section     String
  title       String?
  subtitle    String?
  description String?
  imageUrl    String
  altText     String?
  tone        String?
  variant     String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id               String         @id @default(cuid())
  category         String
  title            String
  model            String?
  slug             String         @unique
  shortDescription String
  contentHtml      String?        @db.Text
  tags             String[]       @default([])
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  images           ProductImage[]
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  altText   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model SiteSettings {
  id                       String   @id @default("default")
  companyName              String
  companyShortName         String
  companyHomeAriaLabel     String
  companyTagline           String
  companyDistributorLabel  String
  companyDistributorValue  String
  companyQuoteButton       String
  companyLogoUrl           String?
  companyLogoAltText       String?
  faviconUrl               String?
  contactPhone             String
  contactHours             String
  contactAddressFull       String
  contactAddressShort      String
  contactEmail             String
  contactEmailAriaLabel    String
  contactFacebookUrl       String
  contactFacebookAriaLabel String
  contactZaloUrl           String?
  contactMessengerUrl      String?
  contactGoogleMapUrl      String?
  footerContactInfoTitle   String?
  footerRightsText         String?
  footerCopyrightStartYear Int?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model SiteContent {
  id             String   @id @default("default")
  nav            Json
  hero           Json
  stats          Json
  previousWorks  Json
  services       Json
  companyProfile Json
  products       Json
  cta            Json
  contactPage    Json
  aboutPage      Json
  footer         Json
  routes         Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model TeamMember {
  id          String   @id @default(cuid())
  fullName    String
  role        String?
  email       String?
  phone       String?
  imageUrl    String?
  bio         String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model AdminUser {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  recoveryEmail String?
  passwordHash String
  role         String   @default("admin")
  isActive     Boolean  @default(true)
  isRoot       Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive, role])
}

model NewsPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  contentHtml String   @db.Text
  coverImage  String?
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished, publishedAt])
  @@index([updatedAt])
}
